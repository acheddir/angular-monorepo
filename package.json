{
  "name": "angular-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "varlock run -- vite --config apps/app/vite.config.mts",
    "build": "pnpm build:app",
    "build:app": "varlock run -- vite build --config apps/app/vite.config.mts",
    "build:schematics": "tsc -p tools/schematics/tsconfig.json && for dir in domain feature data types ui util; do [ -d tools/schematics/$dir/files ] && cp -r tools/schematics/$dir/files tools/schematics/dist/$dir/; done",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint-staged": "lint-staged",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "modules:list": "pnpm exec sheriff list 2>&1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm format:check && pnpm test",
    "prepare": "husky",
    "generate:domain": "ng generate domain",
    "generate:feature": "ng generate feature",
    "generate:data": "ng generate data",
    "generate:types": "ng generate types",
    "generate:ui": "ng generate ui",
    "generate:util": "ng generate util"
  },
  "author": "Abderrahman Cheddir",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.1",
    "@angular-devkit/core": "^22.0.1",
    "@angular-devkit/schematics": "^22.0.1",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.2",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "@tailwindcss/postcss": "^4.1.12",
    "@tools/schematics": "file:./tools/schematics",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@varlock/vite-integration": "^1.2.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.39.2",
    "hono": "^4.11.4",
    "husky": "^9.1.7",
    "inquirer": "^13.2.1",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.2.7",
    "ng-packagr": "^22.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.0",
    "tailwindcss": "^4.1.12",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "varlock": "^1.9.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@openfeature/angular-sdk": "^1.3.1",
    "@openfeature/core": "^1.11.0",
    "@openfeature/web-sdk": "^1.9.0",
    "angular-oauth2-oidc": "^22.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "varlock": {
    "loadPath": "./apps/app/"
  }
}
